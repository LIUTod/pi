{
	"name": "@liutod-scream/pi-tui",
	"version": "0.80.14",
	"description": "Terminal User Interface library with differential rendering for efficient text-based applications (scream-code fork)",
	"type": "module",
	"main": "dist/index.mjs",
	"exports": {
		".": {
			"import": "./dist/index.mjs",
			"types": "./dist/index.d.ts"
		}
	},
	"scripts": {
		"clean": "shx rm -rf dist",
		"build": "tsdown && tsc -p tsconfig.build.json",
		"test": "node --test --test-reporter=dot --test-reporter-destination=stdout test/*.test.ts",
		"prepublishOnly": "npm run clean && npm run build"
	},
	"files": [
		"dist/**/*",
		"native/win32/prebuilds/**/*.node",
		"native/darwin/prebuilds/**/*.node",
		"README.md"
	],
	"keywords": [
		"tui",
		"terminal",
		"ui",
		"text-editor",
		"differential-rendering",
		"typescript",
		"cli",
		"scream-code"
	],
	"author": "Mario Zechner",
	"contributors": [
		"LIUTod"
	],
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/LIUTod/pi.git"
	},
	"engines": {
		"node": ">=22.19.0"
	},
	"types": "./dist/index.d.ts",
	"dependencies": {
		"get-east-asian-width": "1.6.0",
		"marked": "18.0.5"
	},
	"devDependencies": {
		"@types/node": "26.1.1",
		"@xterm/headless": "5.5.0",
		"chalk": "5.6.2",
		"shx": "0.4.0",
		"tsdown": "0.22.8",
		"typescript": "7.0.2"
	}
}
